# ============================================================================
# Fine-Tune MDR — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your keys.
# ============================================================================

# HuggingFace token (for gated model access)
HF_TOKEN=

# NVD API key (free from https://nvd.nist.gov/developers/request-an-api-key)
# Speeds up data refresh by reducing rate limits from 6s to 0.6s per request
NVD_API_KEY=
